{
  "manifest_version": 3,
  "name": "Translate Bot",
  "description": "Translate the current page in place with a local model proxy.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Translate Bot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "Toggle translation on the current page."
    }
  }
}
